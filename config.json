{
  "version": "2.0",
  
  "assistant": {
    "name": "ZIA",
    "wake_word": "hey zia",
    "language": "en-IN",
    "personality_mode": "professional",
    "response_speed": "normal",
    "emotion_support": true
  },

  "voice_settings": {
    "engine": "gtts",
    "voice_gender": "female",
    "voice_accent": "Indian",
    "volume": 80,
    "rate": 1.0
  },

  "security": {
    "face_lock_enabled": true,
    "passcode_enabled": false,
    "auto_lock_time": 300,
    "intruder_alert": true
  },

  "memory": {
    "save_history": true,
    "max_memory_entries": 200,
    "learning_mode": true
  },

  "features": {
    "internet_search": true,
    "weather_system": true,
    "media_player": true,
    "smart_home_control": false,
    "system_commands": true,
    "developer_mode": true
  },

  "display_settings": {
    "theme": "neon_blue",
    "mode": "hacker",
    "show_logs": true
  },

  "network": {
    "wifi_required": true,
    "use_online_ai": true,
    "offline_backup_mode": true
  }
}
